{
  "name": "nss-mis-tools-backend",
  "version": "1.0.0",
  "description": "Backend API for NSS MIS Tools",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed": "node src/seed.js",
    "seed:orgs": "node src/scripts/seedOrganizations.js && node src/scripts/seedMatrix.js",
    "seed:orgs:partial": "node src/scripts/seedOrganizationsPartial.js && node src/scripts/seedMatrix.js",
    "seed:superadmin": "node src/scripts/seedSuperadmin.js",
    "seed:all": "node src/scripts/seedLocations.js && npm run seed:orgs && npm run seed:superadmin",
    "seed:partial": "node src/scripts/seedLocations.js && npm run seed:orgs:partial && npm run seed:superadmin",
    "lint": "eslint .",
    "test": "jest"
  },
  "keywords": ["nss", "mis", "backend", "express", "mongoose"],
  "author": "Your Name <you@example.com>",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.3",
    "multer": "^2.0.2",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "joi": "^17.13.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "eslint": "^9.0.0",
    "jest": "^29.7.0"
  }
}
